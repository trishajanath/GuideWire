GEMINI_API_KEY=your_gemini_api_key
OPENWEATHER_API_KEY=your_openweather_api_key

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/guidewire?retryWrites=true&w=majority
MONGODB_DB_NAME=guidewire
MONGODB_PAYOUT_COLLECTION=payout_transactions
MONGODB_TLS_ALLOW_INVALID_CERTIFICATES=false
MONGODB_TLS_ALLOW_INVALID_HOSTNAMES=false

# Auto-claim generation when weather risk crosses threshold
AUTO_CLAIM_RISK_THRESHOLD=60
AUTO_CLAIM_DEFAULT_HOURS_LOST=1.0
AUTO_CLAIM_COOLDOWN_MINUTES=180
